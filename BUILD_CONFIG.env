# EasyTier Android FFI Builder - CI configuration
# Lines starting with # are comments. No quotes around values.
# This file is read by the GitHub Actions workflow; DO NOT put secrets here.

# EasyTier upstream repository & ref
REPO_URL=https://github.com/EasyTier/EasyTier.git
ET_REF=main

# Android NDK version for CI runner
NDK_VERSION=r27

# Rust targets & cargo profile
RUST_TARGETS=aarch64-linux-android,armv7-linux-androideabi,i686-linux-android,x86_64-linux-android
CARGO_PROFILE=release

# Android ABIs to build (comma-separated). Supported: arm64-v8a,armeabi-v7a,x86,x86_64
ABIS=arm64-v8a,armeabi-v7a,x86,x86_64

# Optional: Path to the official Android JNI Cargo.toml (if auto-detection fails)
# Example: JNI_MANIFEST=third_party/easytier/easytier-contrib/easytier-android-jni/Cargo.toml
JNI_MANIFEST=third_party/easytier/easytier-contrib/easytier-android-jni/Cargo.toml

# Build author / developer
DEVELOPER=MCTDev
